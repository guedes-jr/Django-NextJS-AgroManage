# ─────────────────────────────────────────────
# AgroManage — Backend Environment Variables
# Copy this file to .env and fill in the values
# ─────────────────────────────────────────────

# Django
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=change-me-to-a-random-50-char-string
DJANGO_LOG_LEVEL=INFO
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,.ngrok-free.dev

# Database (SQLite for local dev)
DATABASE_URL=sqlite:///db.sqlite3

# Redis / Celery
REDIS_URL=redis://localhost:6379/0

# CORS — Next.js frontend URL(s)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://retrace-epileptic-varsity.ngrok-free.dev

# Email (SMTP — only needed in production)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=your@email.com
# EMAIL_HOST_PASSWORD=your-app-password

# Sentry DSN (optional — only in production)
# SENTRY_DSN=https://...
