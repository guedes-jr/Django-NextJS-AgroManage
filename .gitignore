# =============================================================================
# AgroManage — .gitignore
# =============================================================================

# ─── Python / Django ─────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
*.manifest
*.spec
pip-log.txt
pip-delete-this-directory.txt

# Virtual environments
.venv/
venv/
env/
ENV/

# Django
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal
backend/media/
backend/staticfiles/

# Node
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/.env.local
frontend/.env.production
frontend/.env.production.local

# pytest / coverage
.pytest_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# ─── Node / Next.js ───────────────────────────────────────────────────────────
node_modules/
.next/
.nuxt/
out/
dist/
build/
.turbo/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ─── Environment files ────────────────────────────────────────────────────────
.env
.env.*
!.env.example
frontend/.env.local

# ─── Docker ───────────────────────────────────────────────────────────────────
docker-compose.override.yml

# ─── IDE / Editor ─────────────────────────────────────────────────────────────
.idea/
.vscode/settings.json
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ─── Misc ─────────────────────────────────────────────────────────────────────
*.bak
*.tmp
*.orig
logs/
tmp/
temp/

# Others 
*lovalbe*/
lovalbe_source/
agro-flow-dashboard-main.zip
